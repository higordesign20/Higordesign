<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Zé Neto Climatização | Especialistas em Ar-Condicionado</title>

<link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700&family=Plus+Jakarta+Sans:wght@400;500;600&display=swap" rel="stylesheet">

<style>

/* RESET */
*, *::before, *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

html {
    scroll-behavior: smooth;
}

body {
    font-family: 'Plus Jakarta Sans', sans-serif;
    background: radial-gradient(circle at 20% 20%, #0a2a3f, #05121c 60%);
    color: white;
    overflow-x: hidden;
}

/* CONTAINER */
.container {
    width: 90%;
    max-width: 1200px;
    margin: auto;
}

/* ===== NAVBAR ===== */
.nav {
    position: fixed;
    top: 0;
    width: 100%;
    padding: 20px 0;
    backdrop-filter: blur(20px);
    background: rgba(0, 0, 0, 0.3);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    z-index: 999;
    transition: 0.4s;
}

.nav.scrolled {
    padding: 12px 0;
    background: rgba(0, 0, 0, 0.65);
    box-shadow: 0 4px 30px rgba(0, 224, 255, 0.08);
}

.nav .container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 40px;
}

/* ===== NAV MENU ===== */
.nav-menu {
    display: flex;
    gap: 8px;
    align-items: center;
}

.nav-menu a {
    padding: 10px 18px;
    border-radius: 50px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    text-decoration: none;
    color: #b6d1e3;
    font-weight: 500;
    font-size: 14px;
    transition: 0.3s;
}

.nav-menu a:hover {
    background: rgba(0, 224, 255, 0.1);
    border-color: rgba(0, 224, 255, 0.3);
    color: #00e0ff;
}

.nav-menu a.active {
    background: rgba(0, 224, 255, 0.15);
    border-color: rgba(0, 224, 255, 0.4);
    color: #00e0ff;
}

@media (max-width: 768px) {
    .nav-menu {
        gap: 4px;
    }
    
    .nav-menu a {
        padding: 8px 12px;
        font-size: 12px;
    }
}

.logo-text {
    font-family: 'Sora', sans-serif;
    font-weight: 700;
    font-size: 22px;
    background: linear-gradient(90deg, #fff, #00e0ff);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    letter-spacing: -0.5px;
}

/* ===== SECTIONS ===== */
section {
    padding: 140px 0;
}

/* ===== HERO ===== */
.hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
}

.hero::before {
    content: '';
    position: absolute;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(0, 224, 255, 0.07) 0%, transparent 70%);
    top: -100px;
    right: -100px;
    pointer-events: none;
}

.hero-grid {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    align-items: center;
    gap: 60px;
}

h1 {
    font-family: 'Sora', sans-serif;
    font-size: 62px;
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -2px;
    background: linear-gradient(90deg, #fff 30%, #00e0ff);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
}

h2 {
    font-family: 'Sora', sans-serif;
    font-size: 38px;
    font-weight: 600;
    margin-bottom: 40px;
    background: linear-gradient(90deg, #fff, #00e0ff);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    display: inline-block;
}

h3 {
    font-family: 'Sora', sans-serif;
    margin-bottom: 10px;
    font-size: 18px;
    font-weight: 600;
}

p {
    color: #b6d1e3;
    margin: 20px 0;
    line-height: 1.75;
    font-size: 15.5px;
}

/* ===== BOTÃO ===== */
.btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 16px 38px;
    border-radius: 50px;
    background: rgba(255, 255, 255, 0.07);
    border: 1px solid rgba(255, 255, 255, 0.2);
    text-decoration: none;
    color: white;
    font-weight: 600;
    font-size: 15px;
    transition: 0.4s;
    cursor: pointer;
}

.btn:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 50px rgba(0, 255, 255, 0.3);
    background: rgba(0, 224, 255, 0.1);
    border-color: rgba(0, 224, 255, 0.4);
}

.btn-primary {
    background: linear-gradient(135deg, rgba(0, 180, 220, 0.3), rgba(0, 80, 120, 0.3));
    border-color: rgba(0, 224, 255, 0.35);
}

/* ===== HERO LOGO ===== */
.hero-logo {
    display: flex;
    justify-content: center;
    position: relative;
}

.hero-logo::after {
    content: '';
    position: absolute;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(0, 224, 255, 0.15), transparent 70%);
    border-radius: 50%;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 0;
}

.hero-logo img {
    width: 100%;
    max-width: 480px;
    filter: drop-shadow(0 40px 80px rgba(0, 255, 255, 0.3));
    animation: floatLogo 4s ease-in-out infinite;
    transition: 0.6s;
    position: relative;
    z-index: 1;
}

.hero-logo img:hover {
    transform: scale(1.05);
}

/* Placeholder quando não há logo */
.hero-logo-placeholder {
    width: 320px;
    height: 320px;
    border-radius: 50%;
    background: radial-gradient(circle at 40% 40%, rgba(0, 180, 220, 0.25), rgba(0, 40, 80, 0.4));
    border: 2px solid rgba(0, 224, 255, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    animation: floatLogo 4s ease-in-out infinite;
    position: relative;
    z-index: 1;
}

.hero-logo-placeholder svg {
    width: 140px;
    height: 140px;
    opacity: 0.7;
}

@keyframes floatLogo {
    0%   { transform: translateY(0); }
    50%  { transform: translateY(-15px); }
    100% { transform: translateY(0); }
}

/* ===== BADGES / STATS ===== */
.hero-badges {
    display: flex;
    gap: 16px;
    margin-top: 30px;
    flex-wrap: wrap;
}

.badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 18px;
    border-radius: 50px;
    background: rgba(0, 224, 255, 0.07);
    border: 1px solid rgba(0, 224, 255, 0.2);
    font-size: 13px;
    font-weight: 600;
    color: #7ee8fa;
}

.badge svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
}

/* ===== SOBRE EMPRESA ===== */
.about-company {
    background: linear-gradient(180deg, #05121c, #071e2c);
    position: relative;
}

.about-company-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 80px;
    align-items: center;
}

.about-highlight {
    display: flex;
    flex-direction: column;
    gap: 20px;
}

.highlight-card {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.09);
    padding: 28px 32px;
    border-radius: 20px;
    backdrop-filter: blur(20px);
    transition: 0.4s;
    display: flex;
    align-items: flex-start;
    gap: 18px;
}

.highlight-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 50px rgba(0, 255, 255, 0.12);
    border-color: rgba(0, 224, 255, 0.2);
}

.highlight-icon {
    width: 48px;
    height: 48px;
    border-radius: 14px;
    background: rgba(0, 224, 255, 0.1);
    border: 1px solid rgba(0, 224, 255, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
}

.highlight-icon svg {
    width: 24px;
    height: 24px;
}

/* ===== SERVIÇOS ===== */
.services {
    background: linear-gradient(180deg, #071e2c, #05121c);
}

.services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 32px;
}

.service-box {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(25px);
    padding: 48px 40px;
    border-radius: 24px;
    transition: 0.6s cubic-bezier(.22, 1, .36, 1);
    transform-style: preserve-3d;
    position: relative;
    overflow: hidden;
}

.service-box::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, rgba(0, 224, 255, 0.5), transparent);
    opacity: 0;
    transition: 0.4s;
}

.service-box:hover::before {
    opacity: 1;
}

.service-box:hover {
    transform: rotateX(4deg) rotateY(-4deg) translateY(-12px);
    box-shadow: 0 40px 80px rgba(0, 255, 255, 0.15);
    border-color: rgba(0, 224, 255, 0.18);
}

.service-icon {
    width: 60px;
    height: 60px;
    border-radius: 18px;
    background: rgba(0, 224, 255, 0.08);
    border: 1px solid rgba(0, 224, 255, 0.18);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
}

.service-icon svg {
    width: 28px;
    height: 28px;
}

/* ===== CONTATO ===== */
.contact {
    background: linear-gradient(180deg, #05121c, #041018);
}

.contact-subtitle {
    color: #9ec6db;
    margin-bottom: 60px;
    margin-top: -20px;
    font-size: 16px;
}

.contact-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 32px;
}

.contact-card {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(25px);
    padding: 48px 40px;
    border-radius: 24px;
    text-decoration: none;
    color: white;
    transition: 0.6s cubic-bezier(.22, 1, .36, 1);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 4px;
    position: relative;
    overflow: hidden;
}

.contact-card::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 2px;
    opacity: 0;
    transition: 0.4s;
}

/* Cores específicas por rede */
.contact-card.email::after     { background: linear-gradient(90deg, #4285F4, #34A853); }
.contact-card.whatsapp::after  { background: linear-gradient(90deg, #25D366, #128C7E); }
.contact-card.instagram::after { background: linear-gradient(90deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888); }

.contact-card:hover::after {
    opacity: 1;
}

.contact-card:hover {
    transform: translateY(-12px);
    box-shadow: 0 40px 80px rgba(0, 255, 255, 0.15);
}

.contact-card.email:hover     { border-color: rgba(66, 133, 244, 0.35); box-shadow: 0 40px 80px rgba(66, 133, 244, 0.15); }
.contact-card.whatsapp:hover  { border-color: rgba(37, 211, 102, 0.35); box-shadow: 0 40px 80px rgba(37, 211, 102, 0.15); }
.contact-card.instagram:hover { border-color: rgba(220, 39, 67, 0.35);  box-shadow: 0 40px 80px rgba(220, 39, 67, 0.12); }

.contact-icon-wrap {
    width: 64px;
    height: 64px;
    border-radius: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
    transition: 0.4s;
}

.contact-card.email .contact-icon-wrap {
    background: rgba(66, 133, 244, 0.12);
    border: 1px solid rgba(66, 133, 244, 0.25);
}

.contact-card.whatsapp .contact-icon-wrap {
    background: rgba(37, 211, 102, 0.12);
    border: 1px solid rgba(37, 211, 102, 0.25);
}

.contact-card.instagram .contact-icon-wrap {
    background: rgba(220, 39, 67, 0.12);
    border: 1px solid rgba(220, 39, 67, 0.25);
}

.contact-card:hover .contact-icon-wrap {
    transform: scale(1.1) rotate(-4deg);
}

.contact-icon-wrap svg {
    width: 32px;
    height: 32px;
}

.contact-label {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    margin-bottom: 4px;
}

.contact-card.email .contact-label     { color: #6aabff; }
.contact-card.whatsapp .contact-label  { color: #4cde85; }
.contact-card.instagram .contact-label { color: #f77; }

.contact-card h3 {
    font-size: 20px;
    margin-bottom: 6px;
}

.contact-card p {
    margin: 0;
    font-size: 14px;
    color: #8fb5cc;
    word-break: break-all;
}

.contact-arrow {
    margin-top: 20px;
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    font-weight: 600;
    opacity: 0.5;
    transition: 0.3s;
}

.contact-card:hover .contact-arrow {
    opacity: 1;
    gap: 10px;
}

.contact-card.email .contact-arrow     { color: #6aabff; }
.contact-card.whatsapp .contact-arrow  { color: #4cde85; }
.contact-card.instagram .contact-arrow { color: #f77; }

/* ===== FOOTER ===== */
.footer {
    padding: 40px 0;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    text-align: center;
}

.footer p {
    margin: 0;
    font-size: 13px;
    color: #4a6a7a;
}

/* ===== ANIMAÇÃO SCROLL ===== */
.hidden {
    opacity: 0;
    transform: translateY(60px) scale(0.97);
    filter: blur(8px);
    transition: 1s cubic-bezier(.22, 1, .36, 1);
}

.show {
    opacity: 1;
    transform: translateY(0) scale(1);
    filter: blur(0);
}

/* ===== RESPONSIVO ===== */
@media (max-width: 900px) {
    .hero-grid {
        grid-template-columns: 1fr;
        text-align: center;
    }

    .hero-logo {
        order: -1;
    }

    .hero-logo img,
    .hero-logo-placeholder {
        max-width: 260px;
        width: 260px;
        height: 260px;
        margin-bottom: 20px;
    }

    .about-company-grid {
        grid-template-columns: 1fr;
    }

    h1 { font-size: 42px; }
    h2 { font-size: 30px; }

    .hero-badges {
        justify-content: center;
    }

    .contact-card {
        align-items: center;
        text-align: center;
    }
}

</style>
</head>
